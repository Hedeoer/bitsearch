# BitSearch Environment Variables
# Copy this file to .env and fill in the values before starting.

# ── Network ────────────────────────────────────────────────────────────────────
APP_PORT=8097
APP_HOST=0.0.0.0
TRUST_PROXY=false

# ── Storage ────────────────────────────────────────────────────────────────────
# Absolute or relative path to the SQLite database file.
# The directory must exist and be writable.
DATABASE_PATH=./data/bitsearch.db

# ── Secrets (REQUIRED in production) ──────────────────────────────────────────
# AES-256-GCM encryption key for stored API keys.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ENCRYPTION_KEY=

# Bearer token for the Admin API (HTTP header: Authorization: Bearer <token>)
ADMIN_AUTH_KEY=

# Session signing secret for the admin login session cookie.
# Example: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Bearer token for the MCP API (HTTP header: Authorization: Bearer <token>)
MCP_BEARER_TOKEN=

# ── Container Image Selection (optional for prebuilt image deployments) ───────
# Used by docker-compose.image.yml when pulling a published image directly.
BITSEARCH_IMAGE=docker.io/hedeoerwang/bitsearch:latest

# ── Runtime ────────────────────────────────────────────────────────────────────
# Set to 'production' to enforce that all secrets above are non-empty.
NODE_ENV=production
