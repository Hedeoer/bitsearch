# BitSearch Environment Variables
# Copy this file to .env and fill in the values before starting.

# ── Network ────────────────────────────────────────────────────────────────────
APP_PORT=8097
APP_HOST=0.0.0.0
TRUST_PROXY=false

# ── Storage ────────────────────────────────────────────────────────────────────
# Absolute or relative path to the SQLite database file.
# The directory must exist and be writable.
DATABASE_PATH=./data/bitsearch.db

# Optional path to the persisted runtime secrets file.
# Defaults to: <DATABASE_PATH directory>/runtime-secrets.json
RUNTIME_SECRETS_FILE=

# ── Secrets (optional; auto-generated + persisted) ────────────────────────────
# Leaving these empty is supported: BitSearch generates missing secrets on first
# boot and stores them in runtime-secrets.json (see RUNTIME_SECRETS_FILE).
# If set, environment variables override the runtime secrets file.
# AES-256-GCM encryption key for stored API keys.
# Generate with: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
APP_ENCRYPTION_KEY=

# Admin login authorization key (used to sign in to the Admin Console).
ADMIN_AUTH_KEY=

# Session signing secret for the admin login session cookie.
# Example: node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
SESSION_SECRET=

# Bearer token for the MCP API (HTTP header: Authorization: Bearer <token>)
MCP_BEARER_TOKEN=

# ── Container Image Selection (used by docker-compose.yml) ────────────────────
# Override this if you want a different published tag or registry mirror.
BITSEARCH_IMAGE=docker.io/hedeoerwang/bitsearch:latest

# ── Runtime ────────────────────────────────────────────────────────────────────
# Use 'production' for deployments. Development mode is more permissive with
# local http base URLs for providers.
NODE_ENV=production
